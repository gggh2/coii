# Linear personal API key (lin_api_*). Generate at https://linear.app/settings/api
LINEAR_API_KEY=

# HMAC secret for inbound Linear webhooks (only needed if you wire up webhooks).
LINEAR_WEBHOOK_SECRET=

# Comma-separated team keys to poll (e.g. "ENG,DESIGN"). Unset = polling disabled.
LINEAR_TEAM_KEYS=

LOG_LEVEL=INFO

# LLM provider selection.
# Format: <provider>/<model-id>. Supported providers: anthropic, openai.
# Future: google, deepseek, etc. — add a Provider impl in app/runtimes/providers/.
# Default if unset: anthropic/claude-sonnet-4-6
LLM_MODEL=

# Provider API keys. Set the one(s) matching the provider in LLM_MODEL above.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
